# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Variables d'environnement
# Copiez ce fichier en .env et remplissez vos valeurs
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── API FastAPI ───────────────────────────────────────────────────────────────
PORT=8000
WORKERS=2
LOG_LEVEL=info
TF_CPP_MIN_LOG_LEVEL=3          # Supprime les logs verbeux de TensorFlow

# ── Dashboard Streamlit ───────────────────────────────────────────────────────
API_URL=http://localhost:8000   # En local ; mettre http://api:8000 pour Docker

# ── Kaggle (pour télécharger le dataset) ─────────────────────────────────────
# Créez vos credentials sur https://www.kaggle.com/settings → API
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# ── Kubernetes / Registry ─────────────────────────────────────────────────────
REGISTRY=your-registry          # Ex: docker.io/monuser ou ghcr.io/monuser
IMAGE_TAG=1.0.0
K8S_NAMESPACE=bitcoin-ts
